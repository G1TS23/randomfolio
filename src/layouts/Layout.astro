---
import { UNIVERSE_IDS, UNIVERSES } from "../universes/index";
import portfolio from "../data/portfolio.json";

// Génère les règles de révélation à partir du registre : chaque univers est
// masqué par défaut, seul celui qui correspond à l'attribut <html data-universe>
// est affiché. Ajouter un univers au registre suffit — aucune CSS à toucher ici.
const revealRules = UNIVERSE_IDS.map(
  (id) =>
    `html[data-universe="${id}"] [data-universe-id="${id}"]{display:block}`,
).join("\n");

const title = `${portfolio.name} — ${portfolio.role}`;
const description = portfolio.tagline;

// URL canonique (Astro.site vient de astro.config.mjs)
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL("/og.png", Astro.site).href;

// Données structurées schema.org : une source canonique et unique pour les
// moteurs, indépendante de l'univers tiré. Contourne la duplication du DOM.
const [locality, country] = portfolio.location.split(",").map((s) => s.trim());
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: portfolio.name,
  jobTitle: portfolio.role,
  description: portfolio.about,
  url: canonical,
  email: `mailto:${portfolio.email}`,
  address: {
    "@type": "PostalAddress",
    addressLocality: locality,
    addressCountry: country ?? undefined,
  },
  sameAs: portfolio.socials.map((s) => s.url),
  knowsAbout: portfolio.skills,
};
---

<!doctype html>
<html lang="fr" data-universe={UNIVERSE_IDS[0]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E%F0%9F%8E%B2%3C/text%3E%3C/svg%3E"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Données structurées (schema.org/Person) -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd)}
      is:inline
    />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Polices : chaque univers pioche dans ce jeu -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;700&family=VT323&family=Archivo+Black&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,900;1,9..144,400&family=Newsreader:ital,wght@0,400;0,500;1,400&display=swap"
      rel="stylesheet"
    />

    <!--
      MOTEUR DE TIRAGE — anti-flash.
      Ce script est `is:inline` : il s'exécute de façon synchrone, dans le <head>,
      AVANT que le <body> ne soit peint. Il fixe data-universe avant tout rendu,
      donc aucun clignotement. Sans JS, l'univers par défaut du serveur reste affiché.
    -->
    <script is:inline define:vars={{ ids: UNIVERSE_IDS }}>
      (function () {
        const KEY = "rf.seen.v1";
        const read = () => {
          try {
            return JSON.parse(localStorage.getItem(KEY)) || {};
          } catch {
            return {};
          }
        };
        const write = (s) => {
          try {
            localStorage.setItem(KEY, JSON.stringify(s));
          } catch {}
        };
        // Tire un univers pas encore vu dans le cycle courant (donc jamais deux
        // fois le même tant qu'on ne les a pas tous parcourus), en évitant
        // `avoid` (ex. l'univers actuel) — donc jamais deux fois d'affilée.
        const pick = (avoid) => {
          const st = read();
          let seen = Array.isArray(st.seen)
            ? st.seen.filter((id) => ids.indexOf(id) !== -1)
            : [];
          let pool = ids.filter(
            (id) => seen.indexOf(id) === -1 && id !== avoid,
          );
          if (pool.length === 0) {
            // cycle terminé → on repart, en évitant seulement le dernier affiché
            seen = [];
            const skip = avoid != null ? avoid : st.last;
            pool = ids.filter((id) => id !== skip);
            if (pool.length === 0) pool = ids.slice();
          }
          const chosen = pool[Math.floor(Math.random() * pool.length)];
          seen.push(chosen);
          write({ seen, last: chosen });
          return chosen;
        };
        window.__rfPick = pick;

        const seed = new URLSearchParams(location.search).get("u");
        const chosen = ids.indexOf(seed) !== -1 ? seed : pick(null);
        document.documentElement.setAttribute("data-universe", chosen);
        // active l'overlay de génération uniquement si JS tourne (anti-flash + fallback sans JS)
        document.documentElement.classList.add("js");
      })();
    </script>

    <style set:html={`.universe{display:none}\n${revealRules}`}></style>

    <style is:global>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        padding: 0;
      }
      body {
        min-height: 100vh;
      }
      a {
        color: inherit;
      }
      img {
        max-width: 100%;
        display: block;
      }
      :focus-visible {
        outline: 3px solid currentColor;
        outline-offset: 2px;
      }

      /* ————————————————————————————————————————————————
         Overlay de génération (au chargement + à chaque tirage)
      ———————————————————————————————————————————————— */
      .genloader {
        position: fixed;
        inset: 0;
        z-index: 10000;
        display: none;
        align-items: center;
        justify-content: center;
        background: #0a0a0c;
        color: #fff;
        font-family: "Inter", system-ui, sans-serif;
      }
      html.js .genloader {
        display: flex;
      }
      /* Sortie « rideau » : le panneau reste opaque et se lève → aucune
         superposition de texte avec l'univers révélé dessous. */
      .genloader.is-done {
        transform: translateY(-101%);
        transition: transform 0.6s cubic-bezier(0.76, 0, 0.24, 1);
        pointer-events: none;
      }
      @media (prefers-reduced-motion: reduce) {
        .genloader.is-done {
          transform: none;
          opacity: 0;
          transition: opacity 0.3s ease;
        }
      }
      .genloader__inner {
        width: min(94vw, 720px);
        padding: 20px;
      }
      /* ——— panneau à palettes façon Solari (aéroport / gare) ——— */
      .sf {
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        background: linear-gradient(#15151a, #0d0d11);
        box-shadow:
          0 30px 80px rgba(0, 0, 0, 0.5),
          inset 0 1px 0 rgba(255, 255, 255, 0.05);
        padding: clamp(14px, 3vw, 26px);
        font-family: "JetBrains Mono", ui-monospace, monospace;
      }
      .sf__head,
      .sf__meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 12px;
        letter-spacing: 0.16em;
        text-transform: uppercase;
      }
      .sf__head {
        color: #ffcf5a;
        padding-bottom: 14px;
        border-bottom: 1px dashed rgba(255, 255, 255, 0.14);
      }
      .sf__head-r {
        color: #83838d;
      }
      .sf__board {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: clamp(3px, 0.8vw, 6px);
        padding: clamp(16px, 3vw, 26px) 0;
        perspective: 340px;
      }
      .sf__cell {
        position: relative;
        display: inline-grid;
        place-items: center;
        width: clamp(22px, 6.2vw, 50px);
        height: clamp(34px, 9vw, 72px);
        border-radius: 4px;
        overflow: hidden;
        perspective: 200px;
        background: linear-gradient(#2c2c34 0 50%, #1d1d23 50% 100%);
        box-shadow:
          inset 0 1px 0 rgba(255, 255, 255, 0.08),
          0 1px 2px rgba(0, 0, 0, 0.4);
      }
      /* volet supérieur qui se rabat à chaque changement de palette */
      .sf__flap {
        position: absolute;
        left: 0;
        right: 0;
        top: 0;
        height: 50%;
        border-radius: 4px 4px 0 0;
        background: linear-gradient(#34343f, #26262e);
        border-bottom: 2px solid rgba(0, 0, 0, 0.65);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.1);
        transform-origin: 50% 100%;
        transform: rotateX(0deg);
        backface-visibility: hidden;
        opacity: 0;
        pointer-events: none;
      }
      .sf__cell::after {
        /* la fente horizontale au milieu de la palette */
        content: "";
        position: absolute;
        left: 0;
        right: 0;
        top: 50%;
        height: 2px;
        transform: translateY(-1px);
        background: rgba(0, 0, 0, 0.55);
        box-shadow: 0 1px 0 rgba(255, 255, 255, 0.05);
      }
      .sf__char {
        font-weight: 700;
        font-size: clamp(1.15rem, 4.2vw, 2.5rem);
        line-height: 1;
        color: #f1ead4;
        will-change: transform;
        backface-visibility: hidden;
      }
      .sf__cell.is-set .sf__char {
        color: #fff;
        text-shadow: 0 0 12px rgba(255, 255, 255, 0.16);
      }
      .sf__meta {
        color: #9a9aa4;
        padding-top: 14px;
        border-top: 1px dashed rgba(255, 255, 255, 0.14);
      }
      .sf__status {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #ffcf5a;
      }
      .sf__status::before {
        content: "";
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #ffcf5a;
        box-shadow: 0 0 10px #ffcf5a;
        animation: sf-blink 1s steps(2, start) infinite;
      }
      @media (prefers-reduced-motion: reduce) {
        .sf__status::before {
          animation: none;
        }
      }
      @keyframes sf-blink {
        50% {
          opacity: 0.25;
        }
      }

      /* ————————————————————————————————————————————————
         Barre de contrôle méta (identique à travers les univers)
         Volontairement neutre pour ne pas concurrencer l'esthétique choisie.
      ———————————————————————————————————————————————— */
      .switcher {
        position: fixed;
        bottom: 18px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 9999;
        display: flex;
        align-items: center;
        gap: 4px;
        padding: 6px;
        border-radius: 999px;
        background: rgba(20, 20, 22, 0.72);
        border: 1px solid rgba(255, 255, 255, 0.14);
        backdrop-filter: blur(14px) saturate(1.2);
        -webkit-backdrop-filter: blur(14px) saturate(1.2);
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.35);
        font-family: "Inter", system-ui, sans-serif;
        color: #fff;
      }
      .switcher button {
        appearance: none;
        border: 0;
        cursor: pointer;
        color: inherit;
        background: transparent;
        font: inherit;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 8px 12px;
        border-radius: 999px;
        font-size: 13px;
        line-height: 1;
        white-space: nowrap;
        transition: background 0.15s ease;
      }
      .switcher button:hover {
        background: rgba(255, 255, 255, 0.12);
      }
      .switcher .switcher__dice {
        font-size: 15px;
      }
      .switcher .switcher__label {
        padding: 8px 12px;
        font-size: 12px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        opacity: 0.75;
        border-left: 1px solid rgba(255, 255, 255, 0.14);
        border-right: 1px solid rgba(255, 255, 255, 0.14);
        white-space: nowrap;
      }
      .switcher__icon {
        font-size: 15px;
        border-left: 1px solid rgba(255, 255, 255, 0.14);
      }
      .switcher__icon.is-muted {
        opacity: 0.5;
      }
      .switcher__toast {
        position: fixed;
        bottom: 74px;
        left: 50%;
        transform: translateX(-50%) translateY(6px);
        z-index: 9999;
        background: #fff;
        color: #111;
        font-family: "Inter", system-ui, sans-serif;
        font-size: 13px;
        padding: 9px 16px;
        border-radius: 999px;
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.25);
        opacity: 0;
        pointer-events: none;
        transition:
          opacity 0.2s ease,
          transform 0.2s ease;
      }
      .switcher__toast.is-visible {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
      }
      /* Sur petit écran : barre compacte, on masque le nom d'univers (redondant)
         pour que « Regénérer » et « Partager » tiennent sur une seule ligne. */
      @media (max-width: 460px) {
        .switcher {
          gap: 2px;
          padding: 5px;
          max-width: calc(100vw - 16px);
        }
        .switcher button {
          padding: 8px 12px;
          font-size: 12px;
        }
        .switcher .switcher__label {
          display: none;
        }
        .switcher__toast {
          max-width: calc(100vw - 24px);
          font-size: 12px;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .switcher button,
        .switcher__toast {
          transition: none;
        }
      }
    </style>
  </head>
  <body>
    <!-- Overlay de génération : panneau à palettes (Solari) qui « affiche » l'univers -->
    <div class="genloader" role="status" aria-live="polite">
      <div class="genloader__inner">
        <div class="sf">
          <div class="sf__head">
            <span class="sf__head-l">✦ Départs</span>
            <span class="sf__head-r">Portfolio · vol RF</span>
          </div>
          <div class="sf__board" data-sf-board aria-hidden="true"></div>
          <div class="sf__meta">
            <span class="sf__status" data-sf-status>Embarquement</span>
            <span class="sf__gate" data-sf-gate>Porte ∞</span>
          </div>
        </div>
      </div>
    </div>

    <slot />

    <!-- Barre de contrôle : regénérer + partager la variante -->
    <nav class="switcher" aria-label="Générateur d'univers">
      <button
        type="button"
        data-action="regen"
        aria-label="Générer un nouvel univers"
      >
        <span class="switcher__dice" aria-hidden="true">🎲</span>
        <span>Regénérer</span>
      </button>
      <span class="switcher__label" data-current>—</span>
      <button
        type="button"
        data-action="share"
        aria-label="Copier le lien de cette variante"
      >
        🔗 Partager
      </button>
      <button
        type="button"
        data-action="sound"
        class="switcher__icon"
        aria-label="Activer ou couper le son du panneau"
        aria-pressed="true"
      >
        <span data-sound-on>🔊</span>
      </button>
    </nav>
    <div class="switcher__toast" role="status" aria-live="polite"></div>

    <script is:inline define:vars={{ universes: UNIVERSES }}>
      const root = document.documentElement;
      const ids = universes.map((u) => u.id);
      const nameOf = (id) =>
        (universes.find((u) => u.id === id) || {}).name || id;

      const label = document.querySelector("[data-current]");
      const toast = document.querySelector(".switcher__toast");
      let toastTimer;

      const switcher = document.querySelector(".switcher");
      const loader = document.querySelector(".genloader");
      const board = loader && loader.querySelector("[data-sf-board]");
      const statusEl = loader && loader.querySelector("[data-sf-status]");
      const gateEl = loader && loader.querySelector("[data-sf-gate]");
      const reduceMotion = matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;
      let sfTimer = null;

      function current() {
        return root.getAttribute("data-universe");
      }
      function render() {
        if (label) label.textContent = nameOf(current());
      }

      // Variation de couleur « dans le même ton » : légère rotation de teinte +
      // saturation appliquée à l'univers affiché (masquée par le loader → pas de
      // flash). Amplitude par univers pour rester dans la bonne famille.
      const TINT = {
        swiss: 60,
        terminal: 34,
        y2k: 46,
        editorial: 65,
        blueprint: 44,
        riso: 52,
        bauhaus: 50,
        aurora: 55,
        memphis: 46,
        botanical: 22,
        comic: 44,
      };
      function applyTint(id) {
        const node = document.querySelector('[data-universe-id="' + id + '"]');
        if (!node) return;
        const range = TINT[id] != null ? TINT[id] : 40;
        // amplitude min. garantie (45–100 % de la plage) → toujours perceptible
        const sign = Math.random() < 0.5 ? -1 : 1;
        const hue = Math.round(sign * range * (0.45 + Math.random() * 0.55));
        const sat = (0.85 + Math.random() * 0.4).toFixed(2);
        node.style.filter = "hue-rotate(" + hue + "deg) saturate(" + sat + ")";
      }
      function showToast(msg) {
        if (!toast) return;
        toast.textContent = msg;
        toast.classList.add("is-visible");
        clearTimeout(toastTimer);
        toastTimer = setTimeout(
          () => toast.classList.remove("is-visible"),
          1800,
        );
      }
      function setUniverse(id) {
        root.setAttribute("data-universe", id);
        // URL nettoyée (sans ?u=) : un rechargement régénère un univers aléatoire.
        // Seuls les liens « Partager » portent ?u= pour épingler un univers précis.
        const url = new URL(location.href);
        if (url.searchParams.has("u")) {
          url.searchParams.delete("u");
          history.replaceState({}, "", url);
        }
        render();
        window.scrollTo({ top: 0 });
      }

      function dismissLoader() {
        if (!loader) return;
        loader.classList.add("is-done");
        if (switcher) switcher.style.visibility = "";
        setTimeout(() => {
          loader.style.display = "none";
        }, 640);
      }

      // ————— Écran de chargement : panneau à palettes (Solari) —————
      const SF_CHARS = " ABCDEFGHIJKLMNOPQRSTUVWXYZ·.-0123456789";
      const SF_MIN_W = 8; // largeur minimale du panneau (nombre de palettes)
      const SF_INTERVAL = 76; // ms par palette (assez lent pour bien voir le volet)
      const SF_BASE = 13; // palettes minimales (1re colonne)
      const SF_STEP = 3; // palettes en plus par colonne → cascade gauche→droite
      const NBSP = "\u00A0";

      // ——— son mécanique du panneau (Web Audio, synthétisé — aucun fichier) ———
      let soundOn = true;
      try {
        soundOn = localStorage.getItem("rf.sound") !== "off";
      } catch {}
      let actx = null;
      function audioCtx() {
        const AC =
          window.AudioContext || /** @type {any} */ (window).webkitAudioContext;
        if (!AC) return null;
        if (!actx) {
          try {
            actx = new AC();
          } catch {
            return null;
          }
        }
        if (actx.state === "suspended") actx.resume();
        return actx;
      }
      // un « clac » = courte bouffée de bruit filtrée, façon volet plastique
      function clack(intensity) {
        if (!soundOn || !actx || actx.state !== "running") return;
        const t = actx.currentTime;
        const vol = 0.16 + 0.24 * Math.min(1, intensity || 0.3);
        const dur = 0.04;
        const n = Math.floor(actx.sampleRate * dur);
        const buf = actx.createBuffer(1, n, actx.sampleRate);
        const d = buf.getChannelData(0);
        for (let i = 0; i < n; i++) {
          const env = (1 - i / n) * (1 - i / n); // attaque percussive
          d[i] = (Math.random() * 2 - 1) * env;
        }
        const src = actx.createBufferSource();
        src.buffer = buf;
        const flt = actx.createBiquadFilter();
        flt.type = "bandpass";
        flt.frequency.value = 1700 + Math.random() * 1000;
        flt.Q.value = 1.1;
        const g = actx.createGain();
        g.gain.setValueAtTime(vol, t);
        g.gain.exponentialRampToValueAtTime(0.0008, t + dur);
        src.connect(flt);
        flt.connect(g);
        g.connect(actx.destination);
        src.start(t);
      }

      // Nom mis en majuscules et centré sur une largeur fixe de palettes
      function sfPad(name) {
        const t = name.toUpperCase();
        const w = Math.max(SF_MIN_W, t.length);
        const left = Math.floor((w - t.length) / 2);
        return " ".repeat(left) + t + " ".repeat(w - t.length - left);
      }
      function sfBuild(text) {
        board.replaceChildren();
        const cells = [];
        for (let i = 0; i < text.length; i++) {
          const cell = document.createElement("span");
          cell.className = "sf__cell";
          const ch = document.createElement("span");
          ch.className = "sf__char";
          ch.textContent = NBSP;
          const flap = document.createElement("span");
          flap.className = "sf__flap";
          cell.appendChild(ch);
          cell.appendChild(flap);
          board.appendChild(cell);
          cells.push({ cell, ch, flap });
        }
        return cells;
      }
      // le volet supérieur se rabat vers l'avant puis disparaît (mécanique)
      function sfFlip(flap) {
        flap.animate(
          [
            { transform: "rotateX(0deg)", opacity: 1 },
            { transform: "rotateX(-90deg)", opacity: 1, offset: 0.72 },
            { transform: "rotateX(-90deg)", opacity: 0 },
          ],
          { duration: SF_INTERVAL, easing: "cubic-bezier(.3,0,.4,1)" },
        );
      }
      const sfSet = (ch, i) =>
        (ch.textContent = SF_CHARS[i] === " " ? NBSP : SF_CHARS[i]);

      // Fait tourner les palettes jusqu'à afficher `targetName`, puis `onReveal`.
      function runGenerator(targetName, opts) {
        opts = opts || {};
        if (!loader) {
          if (opts.onReveal) opts.onReveal();
          return;
        }
        if (sfTimer) {
          clearInterval(sfTimer);
          sfTimer = null;
        }
        loader.classList.remove("is-done");
        loader.style.display = "flex";
        if (switcher) switcher.style.visibility = "hidden";
        if (statusEl) statusEl.textContent = "Embarquement";
        if (gateEl)
          gateEl.textContent = "Porte " + (1 + Math.floor(Math.random() * 42));

        const text = sfPad(targetName);
        const cells = sfBuild(text);
        const len = SF_CHARS.length;

        const arrive = () => {
          if (statusEl) statusEl.textContent = "À l'heure";
          if (opts.onReveal) opts.onReveal();
          setTimeout(dismissLoader, 620); // pause pour profiter du panneau
        };

        if (reduceMotion) {
          cells.forEach((c, i) => {
            const idx = SF_CHARS.indexOf(text[i]);
            sfSet(c.ch, idx < 0 ? 0 : idx);
            if (text[i] !== " ") c.cell.classList.add("is-set");
          });
          arrive();
          return;
        }

        const state = cells.map((c, i) => {
          let ti = SF_CHARS.indexOf(text[i]);
          if (ti < 0) ti = 0;
          const flips = SF_BASE + i * SF_STEP;
          const cur = (((ti - flips) % len) + len) % len;
          sfSet(c.ch, cur);
          return {
            cell: c.cell,
            ch: c.ch,
            flap: c.flap,
            cur,
            target: ti,
            done: false,
          };
        });

        sfTimer = setInterval(() => {
          let moved = 0;
          let remaining = 0;
          for (const s of state) {
            if (s.done) continue;
            s.cur = (s.cur + 1) % len;
            sfSet(s.ch, s.cur);
            sfFlip(s.flap);
            moved++;
            if (s.cur === s.target) {
              s.done = true;
              if (SF_CHARS[s.cur] !== " ") s.cell.classList.add("is-set");
            } else {
              remaining++;
            }
          }
          if (moved > 0) clack(moved / state.length);
          if (remaining === 0) {
            clearInterval(sfTimer);
            sfTimer = null;
            arrive();
          }
        }, SF_INTERVAL);
      }

      document
        .querySelector('[data-action="regen"]')
        ?.addEventListener("click", () => {
          if (sfTimer) return; // évite le spam pendant que le panneau tourne
          audioCtx(); // débloque l'audio (geste utilisateur)
          // même mémoire que le rechargement : jamais un univers déjà vu dans
          // le cycle, ni l'actuel (fallback si le head n'a pas exposé __rfPick)
          const others = ids.filter((id) => id !== current());
          const next = window.__rfPick
            ? window.__rfPick(current())
            : others[Math.floor(Math.random() * others.length)];
          runGenerator(nameOf(next), {
            quick: true,
            onReveal: () => {
              setUniverse(next); // retire ?u= → rechargement reste aléatoire
              applyTint(next); // nouvelle teinte, masquée par le loader
            },
          });
        });

      document
        .querySelector('[data-action="share"]')
        ?.addEventListener("click", async () => {
          const url = new URL(location.href);
          url.searchParams.set("u", current());
          try {
            await navigator.clipboard.writeText(url.toString());
            showToast("Lien copié ✓");
          } catch {
            showToast(url.toString());
          }
        });

      // Bouton son : coupe / active le « clac » du panneau (préférence mémorisée)
      const soundBtn = document.querySelector('[data-action="sound"]');
      function renderSound() {
        if (!soundBtn) return;
        soundBtn.classList.toggle("is-muted", !soundOn);
        soundBtn.setAttribute("aria-pressed", String(soundOn));
        const ic = soundBtn.querySelector("[data-sound-on]");
        if (ic) ic.textContent = soundOn ? "🔊" : "🔇";
      }
      soundBtn?.addEventListener("click", () => {
        soundOn = !soundOn;
        try {
          localStorage.setItem("rf.sound", soundOn ? "on" : "off");
        } catch {}
        if (soundOn) {
          audioCtx();
          clack(0.7); // petit retour audio à l'activation
        }
        renderSound();
      });
      renderSound();

      // Débloque le contexte audio dès la 1re interaction (anti-autoplay des
      // navigateurs). Ainsi le « clac » du bouton Regénérer / touche R marche.
      const unlockAudio = () => {
        const ac = audioCtx();
        if (ac) {
          // buffer silencieux joué dans le geste → débloque iOS Safari
          const b = ac.createBuffer(1, 1, ac.sampleRate);
          const s = ac.createBufferSource();
          s.buffer = b;
          s.connect(ac.destination);
          s.start(0);
        }
        removeEventListener("pointerdown", unlockAudio);
        removeEventListener("keydown", unlockAudio);
      };
      addEventListener("pointerdown", unlockAudio);
      addEventListener("keydown", unlockAudio);

      // Raccourci clavier : "r" pour regénérer
      addEventListener("keydown", (e) => {
        if (e.key === "r" && !e.metaKey && !e.ctrlKey && !e.altKey) {
          const tag = document.activeElement?.tagName;
          if (tag === "INPUT" || tag === "TEXTAREA") return;
          document.querySelector('[data-action="regen"]')?.click();
        }
      });

      render();
      applyTint(current()); // teinte de l'univers au chargement (masquée par le loader)
      // Mise en scène du tirage au chargement (univers déjà posé par le head)
      runGenerator(nameOf(current()));
    </script>
  </body>
</html>
