---
import { UNIVERSE_IDS, UNIVERSES } from "../universes/index";
import portfolio from "../data/portfolio.json";

// Génère les règles de révélation à partir du registre : chaque univers est
// masqué par défaut, seul celui qui correspond à l'attribut <html data-universe>
// est affiché. Ajouter un univers au registre suffit — aucune CSS à toucher ici.
const revealRules = UNIVERSE_IDS.map(
  (id) =>
    `html[data-universe="${id}"] [data-universe-id="${id}"]{display:block}`,
).join("\n");

const title = `${portfolio.name} — ${portfolio.role}`;
const description = portfolio.tagline;

// URL canonique (Astro.site vient de astro.config.mjs)
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL("/og.png", Astro.site).href;

// Données structurées schema.org : une source canonique et unique pour les
// moteurs, indépendante de l'univers tiré. Contourne la duplication du DOM.
const [locality, country] = portfolio.location.split(",").map((s) => s.trim());
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: portfolio.name,
  jobTitle: portfolio.role,
  description: portfolio.about,
  url: canonical,
  email: `mailto:${portfolio.email}`,
  address: {
    "@type": "PostalAddress",
    addressLocality: locality,
    addressCountry: country ?? undefined,
  },
  sameAs: portfolio.socials.map((s) => s.url),
  knowsAbout: portfolio.skills,
};
---

<!doctype html>
<html lang="fr" data-universe={UNIVERSE_IDS[0]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E%F0%9F%8E%B2%3C/text%3E%3C/svg%3E"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Données structurées (schema.org/Person) -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd)}
      is:inline
    />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Polices : chaque univers pioche dans ce jeu -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;700&family=VT323&family=Archivo+Black&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,900;1,9..144,400&family=Newsreader:ital,wght@0,400;0,500;1,400&display=swap"
      rel="stylesheet"
    />

    <!--
      MOTEUR DE TIRAGE — anti-flash.
      Ce script est `is:inline` : il s'exécute de façon synchrone, dans le <head>,
      AVANT que le <body> ne soit peint. Il fixe data-universe avant tout rendu,
      donc aucun clignotement. Sans JS, l'univers par défaut du serveur reste affiché.
    -->
    <script is:inline define:vars={{ ids: UNIVERSE_IDS }}>
      (function () {
        const KEY = "rf.seen.v1";
        const read = () => {
          try {
            return JSON.parse(localStorage.getItem(KEY)) || {};
          } catch {
            return {};
          }
        };
        const write = (s) => {
          try {
            localStorage.setItem(KEY, JSON.stringify(s));
          } catch {}
        };
        // Tire un univers pas encore vu dans le cycle courant (donc jamais deux
        // fois le même tant qu'on ne les a pas tous parcourus), en évitant
        // `avoid` (ex. l'univers actuel) — donc jamais deux fois d'affilée.
        const pick = (avoid) => {
          const st = read();
          let seen = Array.isArray(st.seen)
            ? st.seen.filter((id) => ids.indexOf(id) !== -1)
            : [];
          let pool = ids.filter(
            (id) => seen.indexOf(id) === -1 && id !== avoid,
          );
          if (pool.length === 0) {
            // cycle terminé → on repart, en évitant seulement le dernier affiché
            seen = [];
            const skip = avoid != null ? avoid : st.last;
            pool = ids.filter((id) => id !== skip);
            if (pool.length === 0) pool = ids.slice();
          }
          const chosen = pool[Math.floor(Math.random() * pool.length)];
          seen.push(chosen);
          write({ seen, last: chosen });
          return chosen;
        };
        window.__rfPick = pick;

        const seed = new URLSearchParams(location.search).get("u");
        const chosen = ids.indexOf(seed) !== -1 ? seed : pick(null);
        document.documentElement.setAttribute("data-universe", chosen);
        // active l'overlay de génération uniquement si JS tourne (anti-flash + fallback sans JS)
        document.documentElement.classList.add("js");
      })();
    </script>

    <style set:html={`.universe{display:none}\n${revealRules}`}></style>

    <style is:global>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        padding: 0;
      }
      body {
        min-height: 100vh;
      }
      a {
        color: inherit;
      }
      img {
        max-width: 100%;
        display: block;
      }
      :focus-visible {
        outline: 3px solid currentColor;
        outline-offset: 2px;
      }

      /* ————————————————————————————————————————————————
         Overlay de génération (au chargement + à chaque tirage)
      ———————————————————————————————————————————————— */
      .genloader {
        position: fixed;
        inset: 0;
        z-index: 10000;
        display: none;
        align-items: center;
        justify-content: center;
        background: #0a0a0c;
        color: #fff;
        font-family: "Inter", system-ui, sans-serif;
      }
      html.js .genloader {
        display: flex;
      }
      /* Sortie « rideau » : le panneau reste opaque et se lève → aucune
         superposition de texte avec l'univers révélé dessous. */
      .genloader.is-done {
        transform: translateY(-101%);
        transition: transform 0.6s cubic-bezier(0.76, 0, 0.24, 1);
        pointer-events: none;
      }
      @media (prefers-reduced-motion: reduce) {
        .genloader.is-done {
          transform: none;
          opacity: 0;
          transition: opacity 0.3s ease;
        }
      }
      .genloader__inner {
        text-align: center;
        padding: 24px;
        width: min(90vw, 540px);
      }
      .genloader__dice {
        display: inline-block;
        font-size: 30px;
        line-height: 1;
        margin-bottom: 20px;
      }
      .genloader.is-rolling .genloader__dice {
        animation: gen-roll 0.5s linear infinite;
      }
      @keyframes gen-roll {
        0% {
          transform: rotate(0) scale(1);
        }
        50% {
          transform: rotate(180deg) scale(1.15);
        }
        100% {
          transform: rotate(360deg) scale(1);
        }
      }
      .genloader__eyebrow {
        display: block;
        font-size: 12px;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: #83838d;
        margin-bottom: 14px;
      }
      .genloader__reel {
        display: flex;
        align-items: center;
        justify-content: center;
        /* taille portée par le conteneur pour que le em du min-height soit correct */
        font-size: clamp(2.4rem, 9vw, 4.6rem);
        line-height: 1;
        min-height: 1.25em; /* contient entièrement le nom, ascendantes comprises */
        padding: 0.12em 8px; /* marge pour le petit rebond de l'animation */
      }
      .genloader__name {
        font-family: "Space Grotesk", sans-serif;
        font-weight: 700;
        font-size: 1em;
        line-height: 1;
        letter-spacing: -0.02em;
        color: #f4f4f6;
        will-change: transform, opacity, filter;
      }
      .genloader__name.is-final {
        color: #fff;
        text-shadow: 0 0 34px rgba(255, 255, 255, 0.28);
      }
      .genloader__bar {
        margin: 28px auto 0;
        width: 100%;
        height: 2px;
        background: rgba(255, 255, 255, 0.12);
        border-radius: 2px;
        overflow: hidden;
      }
      .genloader__bar span {
        display: block;
        height: 100%;
        width: 0;
        background: #fff;
      }
      .genloader__hint {
        display: block;
        margin-top: 16px;
        font-size: 11px;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: #83838d;
      }
      @media (prefers-reduced-motion: reduce) {
        .genloader.is-rolling .genloader__dice {
          animation: none;
        }
      }

      /* ————————————————————————————————————————————————
         Barre de contrôle méta (identique à travers les univers)
         Volontairement neutre pour ne pas concurrencer l'esthétique choisie.
      ———————————————————————————————————————————————— */
      .switcher {
        position: fixed;
        bottom: 18px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 9999;
        display: flex;
        align-items: center;
        gap: 4px;
        padding: 6px;
        border-radius: 999px;
        background: rgba(20, 20, 22, 0.72);
        border: 1px solid rgba(255, 255, 255, 0.14);
        backdrop-filter: blur(14px) saturate(1.2);
        -webkit-backdrop-filter: blur(14px) saturate(1.2);
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.35);
        font-family: "Inter", system-ui, sans-serif;
        color: #fff;
      }
      .switcher button {
        appearance: none;
        border: 0;
        cursor: pointer;
        color: inherit;
        background: transparent;
        font: inherit;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 8px 12px;
        border-radius: 999px;
        font-size: 13px;
        line-height: 1;
        white-space: nowrap;
        transition: background 0.15s ease;
      }
      .switcher button:hover {
        background: rgba(255, 255, 255, 0.12);
      }
      .switcher .switcher__dice {
        font-size: 15px;
      }
      .switcher .switcher__label {
        padding: 8px 12px;
        font-size: 12px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        opacity: 0.75;
        border-left: 1px solid rgba(255, 255, 255, 0.14);
        border-right: 1px solid rgba(255, 255, 255, 0.14);
        white-space: nowrap;
      }
      .switcher__toast {
        position: fixed;
        bottom: 74px;
        left: 50%;
        transform: translateX(-50%) translateY(6px);
        z-index: 9999;
        background: #fff;
        color: #111;
        font-family: "Inter", system-ui, sans-serif;
        font-size: 13px;
        padding: 9px 16px;
        border-radius: 999px;
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.25);
        opacity: 0;
        pointer-events: none;
        transition:
          opacity 0.2s ease,
          transform 0.2s ease;
      }
      .switcher__toast.is-visible {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
      }
      /* Sur petit écran : barre compacte, on masque le nom d'univers (redondant)
         pour que « Regénérer » et « Partager » tiennent sur une seule ligne. */
      @media (max-width: 460px) {
        .switcher {
          gap: 2px;
          padding: 5px;
          max-width: calc(100vw - 16px);
        }
        .switcher button {
          padding: 8px 12px;
          font-size: 12px;
        }
        .switcher .switcher__label {
          display: none;
        }
        .switcher__toast {
          max-width: calc(100vw - 24px);
          font-size: 12px;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .switcher button,
        .switcher__toast {
          transition: none;
        }
      }
    </style>
  </head>
  <body>
    <!-- Overlay de génération : mis en scène le tirage aléatoire de l'univers -->
    <div class="genloader" role="status" aria-live="polite">
      <div class="genloader__inner">
        <span class="genloader__dice" aria-hidden="true">🎲</span>
        <span class="genloader__eyebrow">Portfolio aléatoire</span>
        <div class="genloader__reel"><span class="genloader__name"></span></div>
        <div class="genloader__bar"><span></span></div>
        <span class="genloader__hint">génération d’un univers…</span>
      </div>
    </div>

    <slot />

    <!-- Barre de contrôle : regénérer + partager la variante -->
    <nav class="switcher" aria-label="Générateur d'univers">
      <button
        type="button"
        data-action="regen"
        aria-label="Générer un nouvel univers"
      >
        <span class="switcher__dice" aria-hidden="true">🎲</span>
        <span>Regénérer</span>
      </button>
      <span class="switcher__label" data-current>—</span>
      <button
        type="button"
        data-action="share"
        aria-label="Copier le lien de cette variante"
      >
        🔗 Partager
      </button>
    </nav>
    <div class="switcher__toast" role="status" aria-live="polite"></div>

    <script is:inline define:vars={{ universes: UNIVERSES }}>
      const root = document.documentElement;
      const ids = universes.map((u) => u.id);
      const names = universes.map((u) => u.name);
      const nameOf = (id) =>
        (universes.find((u) => u.id === id) || {}).name || id;

      const label = document.querySelector("[data-current]");
      const toast = document.querySelector(".switcher__toast");
      let toastTimer;

      const switcher = document.querySelector(".switcher");
      const loader = document.querySelector(".genloader");
      const reel = loader && loader.querySelector(".genloader__name");
      const bar = loader && loader.querySelector(".genloader__bar span");
      const hint = loader && loader.querySelector(".genloader__hint");
      const reduceMotion = matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      function current() {
        return root.getAttribute("data-universe");
      }
      function render() {
        if (label) label.textContent = nameOf(current());
      }

      // Variation de couleur « dans le même ton » : légère rotation de teinte +
      // saturation appliquée à l'univers affiché (masquée par le loader → pas de
      // flash). Amplitude par univers pour rester dans la bonne famille.
      const TINT = {
        swiss: 60,
        terminal: 34,
        y2k: 46,
        editorial: 65,
        blueprint: 44,
        riso: 52,
        bauhaus: 50,
      };
      function applyTint(id) {
        const node = document.querySelector('[data-universe-id="' + id + '"]');
        if (!node) return;
        const range = TINT[id] != null ? TINT[id] : 40;
        // amplitude min. garantie (45–100 % de la plage) → toujours perceptible
        const sign = Math.random() < 0.5 ? -1 : 1;
        const hue = Math.round(sign * range * (0.45 + Math.random() * 0.55));
        const sat = (0.85 + Math.random() * 0.4).toFixed(2);
        node.style.filter = "hue-rotate(" + hue + "deg) saturate(" + sat + ")";
      }
      function showToast(msg) {
        if (!toast) return;
        toast.textContent = msg;
        toast.classList.add("is-visible");
        clearTimeout(toastTimer);
        toastTimer = setTimeout(
          () => toast.classList.remove("is-visible"),
          1800,
        );
      }
      function setUniverse(id) {
        root.setAttribute("data-universe", id);
        // URL nettoyée (sans ?u=) : un rechargement régénère un univers aléatoire.
        // Seuls les liens « Partager » portent ?u= pour épingler un univers précis.
        const url = new URL(location.href);
        if (url.searchParams.has("u")) {
          url.searchParams.delete("u");
          history.replaceState({}, "", url);
        }
        render();
        window.scrollTo({ top: 0 });
      }

      // ————— Animation de génération (machine à sous → univers tiré) —————
      function pop(el) {
        el.animate(
          [
            {
              transform: "translateY(8px) scale(.88)",
              opacity: 0,
              filter: "blur(3px)",
            },
            { transform: "none", opacity: 1, filter: "blur(0)" },
          ],
          { duration: 130, easing: "cubic-bezier(.2,.7,.2,1)" },
        );
      }
      function dismissLoader() {
        if (!loader) return;
        loader.classList.add("is-done");
        if (switcher) switcher.style.visibility = "";
        setTimeout(() => {
          loader.style.display = "none";
        }, 640);
      }
      // Fait défiler les noms d'univers en décélérant, s'arrête sur `targetName`.
      // `onReveal` est appelé à l'atterrissage (pour poser l'univers sous l'overlay).
      function runGenerator(targetName, opts) {
        opts = opts || {};
        if (!loader) {
          if (opts.onReveal) opts.onReveal();
          return;
        }
        loader.classList.remove("is-done");
        loader.style.display = "flex";
        if (switcher) switcher.style.visibility = "hidden"; // évite le bleed via backdrop-filter
        reel.classList.remove("is-final");
        if (hint) hint.textContent = "génération d’un univers…";
        bar.style.transition = "none";
        bar.style.width = "0%";
        void bar.offsetWidth; // reflow pour rejouer la barre

        if (reduceMotion) {
          reel.textContent = targetName;
          reel.classList.add("is-final");
          if (hint) hint.textContent = "univers sélectionné";
          bar.style.transition = "width .3s linear";
          bar.style.width = "100%";
          if (opts.onReveal) opts.onReveal();
          setTimeout(dismissLoader, 480);
          return;
        }

        const delays = opts.quick
          ? [40, 45, 55, 70, 95, 140, 200]
          : [45, 45, 50, 60, 70, 85, 105, 135, 180, 240];
        const total = delays.reduce((a, b) => a + b, 0);
        bar.style.transition = "width " + total + "ms cubic-bezier(.2,.6,.2,1)";
        bar.style.width = "100%";
        loader.classList.add("is-rolling");

        let i = 0;
        (function tick() {
          const last = i === delays.length - 1;
          reel.textContent = last
            ? targetName
            : names[Math.floor(Math.random() * names.length)];
          pop(reel);
          if (last) {
            loader.classList.remove("is-rolling");
            reel.classList.add("is-final");
            if (hint) hint.textContent = "univers sélectionné";
            if (opts.onReveal) opts.onReveal();
            setTimeout(dismissLoader, 380);
            return;
          }
          setTimeout(tick, delays[i++]);
        })();
      }

      document
        .querySelector('[data-action="regen"]')
        ?.addEventListener("click", () => {
          if (loader && loader.classList.contains("is-rolling")) return; // évite le spam
          // même mémoire que le rechargement : jamais un univers déjà vu dans
          // le cycle, ni l'actuel (fallback si le head n'a pas exposé __rfPick)
          const others = ids.filter((id) => id !== current());
          const next = window.__rfPick
            ? window.__rfPick(current())
            : others[Math.floor(Math.random() * others.length)];
          runGenerator(nameOf(next), {
            quick: true,
            onReveal: () => {
              setUniverse(next); // retire ?u= → rechargement reste aléatoire
              applyTint(next); // nouvelle teinte, masquée par le loader
            },
          });
        });

      document
        .querySelector('[data-action="share"]')
        ?.addEventListener("click", async () => {
          const url = new URL(location.href);
          url.searchParams.set("u", current());
          try {
            await navigator.clipboard.writeText(url.toString());
            showToast("Lien copié ✓");
          } catch {
            showToast(url.toString());
          }
        });

      // Raccourci clavier : "r" pour regénérer
      addEventListener("keydown", (e) => {
        if (e.key === "r" && !e.metaKey && !e.ctrlKey && !e.altKey) {
          const tag = document.activeElement?.tagName;
          if (tag === "INPUT" || tag === "TEXTAREA") return;
          document.querySelector('[data-action="regen"]')?.click();
        }
      });

      render();
      applyTint(current()); // teinte de l'univers au chargement (masquée par le loader)
      // Mise en scène du tirage au chargement (univers déjà posé par le head)
      runGenerator(nameOf(current()));
    </script>
  </body>
</html>
