---
import type { Portfolio } from "../data/schema";
interface Props {
  data: Portfolio;
}
const { data } = Astro.props;
// marqueur géométrique + couleur, en rotation par projet
const shapes = ["circle", "triangle", "square", "half"];
const hues = ["red", "blue", "yellow"];
const total = String(data.projects.length).padStart(2, "0");
---

<section class="universe ba" data-universe-id="bauhaus">
  <div class="ba__wrap">
    <header class="ba__head">
      <span class="ba__eyebrow">{data.role} — {data.location}</span>
      <div class="ba__hero">
        <h1 class="ba__name">{data.name}</h1>
        <div class="ba__shapes" aria-hidden="true">
          <span class="ba__shape ba__shape--circle"></span>
          <span class="ba__shape ba__shape--quarter"></span>
          <span class="ba__shape ba__shape--bar"></span>
        </div>
      </div>
      <p class="ba__tagline">{data.tagline}</p>
      <span class="ba__status" data-on={data.available}>
        {data.available ? "Disponible" : "Complet"}
      </span>
    </header>

    <section class="ba__about">
      <span class="ba__tri" aria-hidden="true"></span>
      <p>{data.about}</p>
    </section>

    <section class="ba__work" aria-label="Projets">
      <div class="ba__work-head">
        <h2>Travaux</h2>
        <span class="ba__count">01 / {total}</span>
      </div>
      <div class="ba__grid">
        {
          data.projects.map((p, i) => (
            <a
              class={`ba__card ba__card--${hues[i % hues.length]}`}
              href={p.url}
            >
              <span
                class={`ba__mark ba__mark--${shapes[i % shapes.length]}`}
                aria-hidden="true"
              />
              <span class="ba__card-meta">
                <span>{p.role}</span>
                <span>{p.year}</span>
              </span>
              <h3 class="ba__card-title">{p.title}</h3>
              <p class="ba__card-desc">{p.description}</p>
              <span class="ba__card-tags">
                {p.tags.map((t) => (
                  <span class="ba__tag">{t}</span>
                ))}
              </span>
            </a>
          ))
        }
      </div>
    </section>

    <section class="ba__skills">
      <h2>Outils</h2>
      <ul>
        {data.skills.map((s) => <li>{s}</li>)}
      </ul>
    </section>

    <footer class="ba__foot">
      <div class="ba__foot-shapes" aria-hidden="true">
        <span class="ba__shape ba__shape--circle ba__shape--sm"></span>
        <span class="ba__shape ba__shape--sq"></span>
      </div>
      <a class="ba__mail" href={`mailto:${data.email}`}>{data.email}</a>
      <ul class="ba__socials">
        {
          data.socials.map((s) => (
            <li>
              <a href={s.url}>{s.label}</a>
            </li>
          ))
        }
      </ul>
    </footer>
  </div>
</section>

<style>
  .ba {
    --paper: #f2eee3;
    --ink: #17130f;
    --red: #e0301e;
    --blue: #164ca3;
    --yellow: #f5b813;
    background: var(--paper);
    color: var(--ink);
    font-family: "Space Grotesk", sans-serif;
    min-height: 100vh;
    padding: clamp(20px, 4vw, 56px) clamp(20px, 4vw, 56px) 104px;
    -webkit-font-smoothing: antialiased;
  }
  .ba__wrap {
    max-width: 1080px;
    margin: 0 auto;
  }

  .ba__eyebrow {
    display: block;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    border-bottom: 3px solid var(--ink);
    padding-bottom: 12px;
  }

  .ba__hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: clamp(16px, 4vw, 48px);
    flex-wrap: wrap;
    padding: clamp(28px, 6vw, 64px) 0 clamp(12px, 2vw, 20px);
  }
  .ba__name {
    flex: 1 1 260px;
    font-family: "Archivo Black", sans-serif;
    font-weight: 400;
    font-size: clamp(2.8rem, 11vw, 7.5rem);
    line-height: 0.9;
    letter-spacing: -0.02em;
    margin: 0;
    max-width: 14ch;
  }
  /* bloc géométrique à côté du nom (jamais par-dessus) */
  .ba__shapes {
    position: relative;
    flex: 0 0 auto;
    width: clamp(120px, 22vw, 190px);
    height: clamp(120px, 22vw, 190px);
  }
  .ba__shape {
    position: absolute;
  }
  .ba__shape--circle {
    width: 62%;
    height: 62%;
    border-radius: 50%;
    background: var(--red);
    top: 0;
    right: 0;
  }
  .ba__shape--quarter {
    width: 46%;
    height: 46%;
    background: var(--blue);
    border-radius: 0 0 100% 0;
    left: 0;
    bottom: 0;
  }
  .ba__shape--bar {
    width: 72%;
    height: 16px;
    background: var(--yellow);
    left: 8%;
    top: 42%;
    transform: rotate(-45deg);
  }
  .ba__tagline {
    position: relative;
    z-index: 2;
    font-size: clamp(1.2rem, 3vw, 2rem);
    font-weight: 500;
    max-width: 20ch;
    margin: 12px 0 0;
    line-height: 1.15;
  }
  .ba__status {
    display: inline-block;
    margin-top: 20px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 6px 14px;
    border: 2px solid var(--ink);
    background: var(--yellow);
  }
  .ba__status[data-on="false"] {
    background: transparent;
  }

  .ba__about {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 24px;
    align-items: start;
    padding: clamp(28px, 5vw, 52px) 0;
    border-top: 3px solid var(--ink);
    margin-top: clamp(24px, 4vw, 40px);
  }
  .ba__tri {
    width: 0;
    height: 0;
    border-left: 34px solid transparent;
    border-right: 34px solid transparent;
    border-bottom: 58px solid var(--blue);
    margin-top: 6px;
  }
  .ba__about p {
    margin: 0;
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    line-height: 1.45;
    max-width: 54ch;
  }

  .ba__work-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    border-top: 3px solid var(--ink);
    padding-top: 14px;
  }
  .ba__work-head h2,
  .ba__skills h2 {
    font-family: "Archivo Black", sans-serif;
    font-weight: 400;
    font-size: clamp(1.6rem, 4vw, 2.6rem);
    margin: 0;
    text-transform: uppercase;
  }
  .ba__count {
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }
  .ba__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
    gap: 20px;
    margin-top: 24px;
  }
  .ba__card {
    position: relative;
    display: block;
    text-decoration: none;
    color: var(--ink);
    background: var(--paper);
    border: 3px solid var(--ink);
    padding: 22px 20px 20px;
    overflow: hidden;
    transition:
      transform 0.14s ease,
      box-shadow 0.14s ease;
  }
  .ba__card:hover {
    transform: translate(-3px, -3px);
    box-shadow: 8px 8px 0 var(--ink);
  }
  .ba__card--red {
    border-top: 14px solid var(--red);
  }
  .ba__card--blue {
    border-top: 14px solid var(--blue);
  }
  .ba__card--yellow {
    border-top: 14px solid var(--yellow);
  }
  .ba__mark {
    position: absolute;
    top: 22px;
    right: 20px;
    width: 26px;
    height: 26px;
  }
  .ba__mark--circle {
    border-radius: 50%;
    background: var(--red);
  }
  .ba__mark--square {
    background: var(--blue);
  }
  .ba__mark--half {
    background: var(--yellow);
    border-radius: 100% 0 0 100%;
  }
  .ba__mark--triangle {
    width: 0;
    height: 0;
    border-left: 13px solid transparent;
    border-right: 13px solid transparent;
    border-bottom: 24px solid var(--red);
    background: transparent;
  }
  .ba__card-meta {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    max-width: calc(100% - 40px);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    opacity: 0.7;
  }
  .ba__card-title {
    font-family: "Archivo Black", sans-serif;
    font-weight: 400;
    font-size: clamp(1.5rem, 3.5vw, 2.1rem);
    line-height: 0.95;
    margin: 10px 0 8px;
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
    text-decoration-color: var(--ink);
  }
  .ba__card-desc {
    font-size: 1rem;
    line-height: 1.4;
    margin: 0 0 14px;
  }
  .ba__card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .ba__tag {
    font-size: 12px;
    font-weight: 600;
    padding: 3px 9px;
    border: 2px solid var(--ink);
    border-radius: 999px;
  }

  .ba__skills {
    padding: clamp(36px, 5vw, 56px) 0 0;
    border-top: 3px solid var(--ink);
    margin-top: clamp(32px, 5vw, 52px);
  }
  .ba__skills ul {
    list-style: none;
    margin: 18px 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .ba__skills li {
    font-weight: 600;
    font-size: 1.05rem;
    padding: 8px 16px;
    border: 2px solid var(--ink);
  }
  .ba__skills li:nth-child(3n + 1) {
    background: var(--red);
    color: var(--paper);
    border-color: var(--red);
  }
  .ba__skills li:nth-child(3n + 2) {
    background: var(--blue);
    color: var(--paper);
    border-color: var(--blue);
  }
  .ba__skills li:nth-child(3n) {
    background: var(--yellow);
  }

  .ba__foot {
    position: relative;
    text-align: center;
    padding-top: clamp(44px, 7vw, 72px);
  }
  .ba__foot-shapes {
    display: flex;
    gap: 14px;
    justify-content: center;
    margin-bottom: 22px;
  }
  .ba__shape--sm {
    position: static;
    width: 30px;
    height: 30px;
  }
  .ba__shape--sq {
    position: static;
    width: 30px;
    height: 30px;
    background: var(--blue);
  }
  .ba__mail {
    font-family: "Archivo Black", sans-serif;
    font-size: clamp(1.4rem, 5vw, 3rem);
    color: var(--ink);
    text-decoration: underline;
    text-decoration-thickness: 3px;
    text-underline-offset: 6px;
    text-decoration-color: var(--red);
    word-break: break-all;
  }
  .ba__socials {
    list-style: none;
    display: flex;
    gap: 22px;
    justify-content: center;
    margin: 22px 0 0;
    padding: 0;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 14px;
  }
  .ba__socials a {
    text-decoration: underline;
    text-decoration-color: var(--blue);
    text-underline-offset: 4px;
  }
  .ba__socials a:hover {
    color: var(--blue);
  }

  @media (max-width: 640px) {
    .ba__about {
      grid-template-columns: 1fr;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .ba__card {
      transition: none;
    }
  }
</style>
