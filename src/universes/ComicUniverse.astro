---
import type { Portfolio } from "../data/schema";
interface Props {
  data: Portfolio;
}
const { data } = Astro.props;
const pows = ["POW!", "ZAP!", "BOOM!", "WOW!", "BANG!", "ZOOM!"];
const fills = ["red", "blue", "yellow"];
---

<section class="universe cm" data-universe-id="comic">
  <div class="cm__wrap">
    <header class="cm__hero">
      <span class="cm__burst" aria-hidden="true">{pows[0]}</span>
      <p class="cm__kicker">
        <span data-i18n="role">{data.role}</span> — {data.location}
      </p>
      <h1 class="cm__name">{data.name}</h1>
      <div class="cm__bubble">
        <p data-i18n="tagline">{data.tagline}</p>
      </div>
    </header>

    <div class="cm__panel cm__about">
      <span class="cm__caption">Origin story</span>
      <p data-i18n="about">{data.about}</p>
    </div>

    <h2 class="cm__h2"><span data-i18n="cm.episodes">Épisodes</span></h2>
    <div class="cm__grid">
      {
        data.projects.map((p, i) => (
          <a
            class={`cm__card cm__card--${fills[i % fills.length]}`}
            href={p.url}
          >
            <div class="cm__card-top">
              <span>{p.year}</span>
              <span data-i18n={`projects.${i}.role`}>{p.role}</span>
            </div>
            <h3 class="cm__card-title" data-i18n={`projects.${i}.title`}>
              {p.title}
            </h3>
            <p class="cm__card-desc" data-i18n={`projects.${i}.description`}>
              {p.description}
            </p>
            <div class="cm__tags">
              {p.tags.map((t, j) => (
                <span class="cm__tag" data-i18n={`projects.${i}.tags.${j}`}>
                  {t}
                </span>
              ))}
            </div>
          </a>
        ))
      }
    </div>

    <div class="cm__panel cm__skills">
      <span class="cm__caption" data-i18n="cm.powers">Super-pouvoirs</span>
      <div class="cm__pills">
        {
          data.skills.map((s, i) => (
            <span class="cm__pill" data-i18n={`skills.${i}`}>
              {s}
            </span>
          ))
        }
      </div>
    </div>

    <footer class="cm__foot">
      <span
        class="cm__burst cm__burst--sm"
        aria-hidden="true"
        data-i18n="cm.hey">HÉ !</span
      >
      <p class="cm__foot-hi" data-i18n="cm.write">Écris-moi</p>
      <a class="cm__mail" href={`mailto:${data.email}`}>{data.email}</a>
      <div class="cm__socials">
        {data.socials.map((s) => <a href={s.url}>{s.label}</a>)}
      </div>
      <span class="cm__end" data-i18n={data.available ? "cm.tbc" : "cm.end"}>
        {data.available ? "À suivre…" : "Fin"}
      </span>
    </footer>
  </div>
</section>

<style>
  .cm {
    --paper: #fdf6e3;
    --ink: #16130d;
    --red: #ff3b30;
    --blue: #2b5bff;
    --yellow: #ffcf2e;
    background-color: var(--paper);
    background-image: radial-gradient(
      rgba(43, 91, 255, 0.16) 1.4px,
      transparent 1.5px
    );
    background-size: 11px 11px;
    color: var(--ink);
    font-family: "Space Grotesk", sans-serif;
    min-height: 100vh;
    position: relative;
    overflow: hidden;
    padding: clamp(20px, 4vw, 56px) clamp(20px, 4vw, 56px) 104px;
  }
  .cm__wrap {
    max-width: 1040px;
    margin: 0 auto;
  }

  /* étoile d'explosion */
  .cm__burst {
    display: inline-grid;
    place-items: center;
    width: clamp(84px, 14vw, 120px);
    height: clamp(84px, 14vw, 120px);
    background: var(--yellow);
    color: var(--ink);
    font-family: "Archivo Black", sans-serif;
    font-size: clamp(14px, 2.4vw, 20px);
    border: 3px solid var(--ink);
    clip-path: polygon(
      50% 0%,
      61% 20%,
      83% 15%,
      78% 38%,
      100% 50%,
      78% 62%,
      83% 85%,
      61% 80%,
      50% 100%,
      39% 80%,
      17% 85%,
      22% 62%,
      0% 50%,
      22% 38%,
      17% 15%,
      39% 20%
    );
    transform: rotate(-8deg);
  }

  .cm__hero {
    position: relative;
    text-align: center;
    padding: clamp(58px, 11vw, 116px) 0 clamp(16px, 3vw, 28px);
  }
  .cm__hero .cm__burst {
    position: absolute;
    top: -8px;
    right: 0;
  }
  .cm__kicker {
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--blue);
    margin: 0;
  }
  .cm__name {
    font-family: "Archivo Black", sans-serif;
    font-weight: 400;
    font-size: clamp(2.8rem, 12vw, 7.5rem);
    line-height: 0.9;
    letter-spacing: -0.01em;
    margin: 10px 0 0;
    color: var(--paper);
    -webkit-text-stroke: 3px var(--ink);
    text-shadow: 5px 5px 0 var(--red);
  }
  .cm__bubble {
    position: relative;
    display: inline-block;
    background: #fff;
    border: 3px solid var(--ink);
    border-radius: 26px;
    padding: 14px 26px;
    margin: 28px auto 0;
    max-width: 30ch;
    box-shadow: 4px 4px 0 var(--ink);
  }
  .cm__bubble p {
    margin: 0;
    font-size: clamp(1.1rem, 2.4vw, 1.5rem);
    font-weight: 600;
    line-height: 1.2;
  }
  /* queue de bulle : petit losange dont l'angle bas-droit forme la pointe */
  .cm__bubble::after {
    content: "";
    position: absolute;
    left: 42px;
    bottom: -10px;
    width: 18px;
    height: 18px;
    background: #fff;
    border-right: 3px solid var(--ink);
    border-bottom: 3px solid var(--ink);
    transform: rotate(45deg);
  }

  .cm__panel {
    background: #fff;
    border: 3px solid var(--ink);
    box-shadow: 6px 6px 0 var(--ink);
    padding: clamp(22px, 4vw, 34px);
    margin: clamp(30px, 5vw, 48px) 0;
  }
  .cm__caption {
    display: inline-block;
    font-family: "Archivo Black", sans-serif;
    font-size: 13px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    background: var(--yellow);
    border: 2px solid var(--ink);
    padding: 3px 12px;
    margin-bottom: 14px;
  }
  .cm__about p {
    margin: 0;
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    line-height: 1.45;
    max-width: 58ch;
    font-weight: 500;
  }

  .cm__h2 {
    text-align: center;
    margin: clamp(20px, 4vw, 36px) 0 24px;
  }
  .cm__h2 span {
    display: inline-block;
    font-family: "Archivo Black", sans-serif;
    font-weight: 400;
    font-size: clamp(1.6rem, 5vw, 2.8rem);
    color: var(--paper);
    background: var(--blue);
    border: 3px solid var(--ink);
    padding: 6px 22px;
    transform: rotate(-1.5deg);
    box-shadow: 4px 4px 0 var(--ink);
  }
  .cm__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(275px, 1fr));
    gap: 22px;
  }
  .cm__card {
    position: relative;
    display: block;
    text-decoration: none;
    color: var(--ink);
    background: #fff;
    border: 3px solid var(--ink);
    box-shadow: 6px 6px 0 var(--ink);
    padding: 26px 22px 22px;
    overflow: hidden;
    transition:
      transform 0.12s ease,
      box-shadow 0.12s ease;
  }
  .cm__card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(currentColor 1.4px, transparent 1.5px);
    background-size: 10px 10px;
    opacity: 0.14;
    pointer-events: none;
  }
  .cm__card--red {
    color: var(--red);
  }
  .cm__card--blue {
    color: var(--blue);
  }
  .cm__card--yellow {
    color: #d99a00;
  }
  .cm__card:hover {
    transform: translate(-3px, -3px);
    box-shadow: 9px 9px 0 var(--ink);
  }
  .cm__card-top {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--ink);
    opacity: 0.65;
    position: relative;
    z-index: 1;
  }
  .cm__card-title {
    position: relative;
    z-index: 1;
    font-family: "Archivo Black", sans-serif;
    font-weight: 400;
    font-size: clamp(1.4rem, 3.5vw, 2rem);
    line-height: 0.95;
    margin: 12px 0 8px;
    color: var(--ink);
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
    text-decoration-color: currentColor;
  }
  .cm__card-desc {
    position: relative;
    z-index: 1;
    font-size: 15px;
    line-height: 1.4;
    font-weight: 500;
    margin: 0 0 14px;
    color: var(--ink);
  }
  .cm__tags {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .cm__tag {
    font-size: 12px;
    font-weight: 700;
    padding: 3px 10px;
    border: 2px solid var(--ink);
    border-radius: 999px;
    background: var(--paper);
    color: var(--ink);
  }

  .cm__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .cm__pill {
    font-weight: 700;
    font-size: 1rem;
    padding: 8px 16px;
    border: 3px solid var(--ink);
    border-radius: 999px;
  }
  .cm__pill:nth-child(3n + 1) {
    background: var(--red);
    color: #fff;
  }
  .cm__pill:nth-child(3n + 2) {
    background: var(--blue);
    color: #fff;
  }
  .cm__pill:nth-child(3n) {
    background: var(--yellow);
  }

  .cm__foot {
    position: relative;
    text-align: center;
    padding-top: clamp(44px, 7vw, 72px);
  }
  .cm__foot .cm__burst--sm {
    position: absolute;
    top: 8px;
    left: clamp(0px, 8vw, 80px);
    width: 74px;
    height: 74px;
    background: var(--red);
    color: #fff;
    font-size: 15px;
    transform: rotate(-12deg);
  }
  .cm__foot-hi {
    font-family: "Archivo Black", sans-serif;
    font-weight: 400;
    font-size: clamp(1.6rem, 5vw, 2.8rem);
    color: var(--blue);
    margin: 0 0 12px;
  }
  .cm__mail {
    font-weight: 700;
    font-size: clamp(1.3rem, 4vw, 2.2rem);
    color: var(--ink);
    text-decoration: underline;
    text-decoration-thickness: 3px;
    text-underline-offset: 6px;
    text-decoration-color: var(--red);
    word-break: break-all;
  }
  .cm__socials {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    justify-content: center;
    margin: 20px 0;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .cm__socials a {
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
    text-decoration-color: var(--blue);
  }
  .cm__socials a:hover {
    color: var(--blue);
  }
  .cm__end {
    display: inline-block;
    font-family: "Archivo Black", sans-serif;
    font-size: 14px;
    letter-spacing: 0.1em;
    color: var(--ink);
    border-top: 3px solid var(--ink);
    padding-top: 10px;
  }

  @media (prefers-reduced-motion: reduce) {
    .cm__card {
      transition: none;
    }
  }
</style>
