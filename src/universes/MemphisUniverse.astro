---
import type { Portfolio } from "../data/schema";
interface Props {
  data: Portfolio;
}
const { data } = Astro.props;
const accents = ["teal", "coral", "yellow", "purple"];
---

<section class="universe mp" data-universe-id="memphis">
  <div class="mp__confetti" aria-hidden="true">
    <span class="mp__c mp__c--dot1"></span>
    <span class="mp__c mp__c--tri1"></span>
    <span class="mp__c mp__c--ring1"></span>
    <svg class="mp__c mp__c--sq1" viewBox="0 0 120 30" fill="none">
      <path
        d="M2 15 Q17 2 32 15 T62 15 T92 15 T118 15"
        stroke="currentColor"
        stroke-width="5"
        stroke-linecap="round"></path>
    </svg>
    <span class="mp__c mp__c--dot2"></span>
    <span class="mp__c mp__c--tri2"></span>
    <span class="mp__c mp__c--bar1"></span>
  </div>

  <div class="mp__wrap">
    <header class="mp__hero">
      <span class="mp__badge" data-i18n="mp.hi">Bonjour !</span>
      <h2 class="mp__name">{data.name}</h2>
      <p class="mp__tagline" data-i18n="tagline">{data.tagline}</p>
      <span class="mp__meta">
        <span data-i18n="role">{data.role}</span> — {data.location} ·{" "}
        <span data-i18n={data.available ? "mp.available" : "mp.busy"}>
          {data.available ? "dispo ✦" : "complet"}
        </span>
      </span>
    </header>

    <div class="mp__about">
      <svg
        class="mp__squiggle"
        viewBox="0 0 120 30"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M2 15 Q17 2 32 15 T62 15 T92 15 T118 15"
          stroke="currentColor"
          stroke-width="5"
          stroke-linecap="round"></path>
      </svg>
      <p data-i18n="about">{data.about}</p>
    </div>

    <h2 class="mp__h2" data-i18n="mp.projects">Mes projets</h2>
    <div class="mp__grid">
      {
        data.projects.map((p, i) => (
          <a
            class={`mp__card mp__card--${accents[i % accents.length]}`}
            href={p.url}
          >
            <span class="mp__card-shape" aria-hidden="true" />
            <div class="mp__card-top">
              <span>{p.year}</span>
              <span data-i18n={`projects.${i}.role`}>{p.role}</span>
            </div>
            <h3 class="mp__card-title" data-i18n={`projects.${i}.title`}>
              {p.title}
            </h3>
            <p class="mp__card-desc" data-i18n={`projects.${i}.description`}>
              {p.description}
            </p>
            <div class="mp__tags">
              {p.tags.map((t, j) => (
                <span class="mp__tag" data-i18n={`projects.${i}.tags.${j}`}>
                  {t}
                </span>
              ))}
            </div>
          </a>
        ))
      }
    </div>

    <div class="mp__skills">
      <h2 class="mp__h2" data-i18n="mp.toolbox">Ma boîte à outils</h2>
      <div class="mp__pills">
        {
          data.skills.map((s, i) => (
            <span class="mp__pill" data-i18n={`skills.${i}`}>
              {s}
            </span>
          ))
        }
      </div>
    </div>

    <footer class="mp__foot">
      <p class="mp__foot-hi" data-i18n="mp.chat">On papote ?</p>
      <a class="mp__mail" href={`mailto:${data.email}`}>{data.email}</a>
      <div class="mp__socials">
        {data.socials.map((s) => <a href={s.url}>{s.label}</a>)}
      </div>
    </footer>
  </div>
</section>

<style>
  .mp {
    --paper: #fbf6ec;
    --ink: #14110f;
    --teal: #12b5a6;
    --coral: #ff6b6b;
    --yellow: #ffcb2b;
    --purple: #7b5ea7;
    background: var(--paper);
    color: var(--ink);
    font-family: "Space Grotesk", sans-serif;
    min-height: 100vh;
    position: relative;
    overflow: hidden;
    padding: clamp(20px, 4vw, 56px) clamp(20px, 4vw, 56px) 104px;
  }

  /* confettis dispersés */
  .mp__confetti {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .mp__c {
    position: absolute;
  }
  .mp__c--dot1 {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--coral);
    top: 12%;
    left: 8%;
  }
  .mp__c--dot2 {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--purple);
    top: 62%;
    left: 6%;
  }
  .mp__c--ring1 {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    border: 6px solid var(--teal);
    top: 30%;
    right: 7%;
  }
  .mp__c--tri1 {
    width: 0;
    height: 0;
    border-left: 16px solid transparent;
    border-right: 16px solid transparent;
    border-bottom: 28px solid var(--yellow);
    top: 74%;
    right: 12%;
    transform: rotate(18deg);
  }
  .mp__c--tri2 {
    width: 0;
    height: 0;
    border-left: 12px solid transparent;
    border-right: 12px solid transparent;
    border-bottom: 20px solid var(--purple);
    top: 8%;
    right: 26%;
    transform: rotate(-24deg);
  }
  .mp__c--bar1 {
    width: 54px;
    height: 12px;
    background: var(--teal);
    border-radius: 999px;
    bottom: 10%;
    left: 40%;
    transform: rotate(-12deg);
  }
  .mp__c--sq1 {
    width: 110px;
    height: 28px;
    color: var(--coral);
    top: 46%;
    left: 3%;
  }

  .mp__wrap {
    position: relative;
    z-index: 1;
    max-width: 1040px;
    margin: 0 auto;
  }

  .mp__hero {
    text-align: center;
    padding: clamp(20px, 4vw, 44px) 0 clamp(16px, 3vw, 28px);
  }
  .mp__badge {
    display: inline-block;
    font-weight: 700;
    font-size: 15px;
    padding: 6px 16px;
    background: var(--yellow);
    border: 3px solid var(--ink);
    border-radius: 999px;
    transform: rotate(-3deg);
  }
  .mp__name {
    font-family: "Archivo Black", sans-serif;
    font-weight: 400;
    font-size: clamp(2.8rem, 12vw, 7.5rem);
    line-height: 0.92;
    letter-spacing: -0.02em;
    margin: 18px 0 0;
    color: var(--ink);
    text-shadow: 4px 4px 0 var(--teal);
  }
  .mp__tagline {
    font-size: clamp(1.2rem, 3vw, 2rem);
    font-weight: 500;
    max-width: 24ch;
    margin: 18px auto 12px;
    line-height: 1.15;
  }
  .mp__meta {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--purple);
  }

  .mp__about {
    position: relative;
    background: #fff;
    border: 3px solid var(--ink);
    border-radius: 22px;
    box-shadow: 7px 7px 0 var(--purple);
    padding: clamp(24px, 4vw, 38px);
    margin: clamp(28px, 5vw, 44px) 0;
  }
  .mp__squiggle {
    display: block;
    width: 96px;
    height: 24px;
    color: var(--coral);
    margin-bottom: 12px;
  }
  .mp__about p {
    margin: 0;
    font-size: clamp(1.1rem, 2vw, 1.45rem);
    line-height: 1.45;
    max-width: 58ch;
  }

  .mp__h2 {
    font-family: "Archivo Black", sans-serif;
    font-weight: 400;
    font-size: clamp(1.6rem, 5vw, 2.6rem);
    text-align: center;
    margin: clamp(34px, 5vw, 52px) 0 24px;
    color: var(--ink);
  }
  .mp__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
    gap: 22px;
  }
  .mp__card {
    position: relative;
    display: block;
    text-decoration: none;
    color: var(--ink);
    background: #fff;
    border: 3px solid var(--ink);
    border-radius: 20px;
    padding: 24px 22px 22px;
    overflow: hidden;
    transition:
      transform 0.14s ease,
      box-shadow 0.14s ease;
  }
  .mp__card--teal {
    box-shadow: 6px 6px 0 var(--teal);
  }
  .mp__card--coral {
    box-shadow: 6px 6px 0 var(--coral);
  }
  .mp__card--yellow {
    box-shadow: 6px 6px 0 var(--yellow);
  }
  .mp__card--purple {
    box-shadow: 6px 6px 0 var(--purple);
  }
  .mp__card:hover {
    transform: translate(-3px, -3px);
  }
  .mp__card--teal:hover {
    box-shadow: 9px 9px 0 var(--teal);
  }
  .mp__card--coral:hover {
    box-shadow: 9px 9px 0 var(--coral);
  }
  .mp__card--yellow:hover {
    box-shadow: 9px 9px 0 var(--yellow);
  }
  .mp__card--purple:hover {
    box-shadow: 9px 9px 0 var(--purple);
  }
  .mp__card-shape {
    position: absolute;
    top: -20px;
    right: -20px;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    opacity: 0.9;
    z-index: 0;
  }
  .mp__card--teal .mp__card-shape {
    background: var(--teal);
  }
  .mp__card--coral .mp__card-shape {
    background: var(--coral);
  }
  .mp__card--yellow .mp__card-shape {
    background: var(--yellow);
  }
  .mp__card--purple .mp__card-shape {
    background: var(--purple);
  }
  .mp__card-top {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: space-between;
    gap: 12px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--purple);
  }
  .mp__card-title {
    font-family: "Archivo Black", sans-serif;
    font-weight: 400;
    font-size: clamp(1.4rem, 3.5vw, 2rem);
    line-height: 0.95;
    margin: 12px 0 8px;
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
    text-decoration-color: var(--coral);
  }
  .mp__card-desc {
    font-size: 15px;
    line-height: 1.4;
    margin: 0 0 14px;
  }
  .mp__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .mp__tag {
    font-size: 12px;
    font-weight: 600;
    padding: 3px 10px;
    border: 2px solid var(--ink);
    border-radius: 999px;
  }

  .mp__skills {
    margin-top: clamp(20px, 4vw, 32px);
  }
  .mp__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
  }
  .mp__pill {
    font-weight: 600;
    font-size: 1rem;
    padding: 8px 16px;
    border: 3px solid var(--ink);
    border-radius: 999px;
    background: #fff;
    color: var(--ink); /* texte foncé lisible sur pastilles claires (AA) */
  }
  .mp__pill:nth-child(4n + 1) {
    background: var(--teal);
  }
  .mp__pill:nth-child(4n + 2) {
    background: var(--coral);
  }
  .mp__pill:nth-child(4n + 3) {
    background: var(--yellow);
  }
  .mp__pill:nth-child(4n) {
    background: var(--purple);
    color: #fff;
  }

  .mp__foot {
    text-align: center;
    padding-top: clamp(40px, 6vw, 64px);
  }
  .mp__foot-hi {
    font-family: "Archivo Black", sans-serif;
    font-weight: 400;
    font-size: clamp(1.6rem, 5vw, 2.8rem);
    color: var(--purple);
    margin: 0 0 14px;
  }
  .mp__mail {
    font-weight: 700;
    font-size: clamp(1.3rem, 4vw, 2.2rem);
    color: var(--ink);
    text-decoration: underline;
    text-decoration-thickness: 3px;
    text-underline-offset: 6px;
    text-decoration-color: var(--coral);
    word-break: break-all;
  }
  .mp__socials {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    justify-content: center;
    margin-top: 22px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .mp__socials a {
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
    text-decoration-color: var(--purple);
  }
  .mp__socials a:hover {
    color: var(--purple);
  }

  @media (prefers-reduced-motion: reduce) {
    .mp__card {
      transition: none;
    }
  }
</style>
