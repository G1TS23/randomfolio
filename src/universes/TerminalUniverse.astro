---
import type { Portfolio } from "../data/schema";
import portfolioEn from "../data/portfolio.en.json";
interface Props {
  data: Portfolio;
}
const { data } = Astro.props;
const user = data.name.toLowerCase().replace(/[^a-z]+/g, "");

// Le REPL est bilingue : on lui passe le contenu FR et EN, et il choisit selon
// <html lang>. Fonctions interdites dans define:vars (JSON) → chaînes seules.
const replContent = (d: Portfolio) => ({
  name: d.name,
  role: d.role,
  about: d.about,
  location: d.location,
  email: d.email,
  projects: d.projects.map((p) => ({
    title: p.title,
    year: p.year,
    description: p.description,
  })),
  skills: d.skills,
  socials: d.socials,
});
const replText = {
  fr: {
    help: [
      "commandes disponibles :",
      "  help · whoami · about · ls · skills · contact",
      "  echo <texte> · date · clear · sudo",
    ],
    sudo: "hé, pas de sudo ici 😏",
    rm: "jamais je ne supprimerai mon propre portfolio 🙃",
    hello: "salut 👋",
    notfound: " : commande introuvable. Tape « help ».",
    locale: "fr-FR",
  },
  en: {
    help: [
      "available commands:",
      "  help · whoami · about · ls · skills · contact",
      "  echo <text> · date · clear · sudo",
    ],
    sudo: "hey, no sudo here 😏",
    rm: "I'll never delete my own portfolio 🙃",
    hello: "hi 👋",
    notfound: ': command not found. Type "help".',
    locale: "en-US",
  },
};
---

<section class="universe tm" data-universe-id="terminal">
  <div class="tm__scanlines" aria-hidden="true"></div>
  <div class="tm__glow" aria-hidden="true"></div>

  <div class="tm__screen">
    <div class="tm__bar">
      <span class="tm__dot tm__dot--r"></span>
      <span class="tm__dot tm__dot--y"></span>
      <span class="tm__dot tm__dot--g"></span>
      <span class="tm__bar-title">{user}@portfolio — zsh</span>
    </div>

    <div class="tm__body">
      <p class="tm__boot">
        [ ok ] <span data-i18n="tm.ready">système prêt</span> · {data.location} ·{
          " "
        }
        <span data-i18n={data.available ? "tm.available" : "tm.busy"}>
          {data.available ? "statut: DISPONIBLE" : "statut: OCCUPÉ"}
        </span>
      </p>

      <p class="tm__line">
        <span class="tm__prompt">{user}@site ~ %</span> whoami
      </p>
      <h2 class="tm__out tm__out--big">{data.name}</h2>
      <p class="tm__out">
        <span data-i18n="role">{data.role}</span> —{" "}
        <span data-i18n="tagline">{data.tagline}</span>
      </p>

      <p class="tm__line">
        <span class="tm__prompt">{user}@site ~ %</span> cat about.txt
      </p>
      <p class="tm__out tm__wrap" data-i18n="about">{data.about}</p>

      <p class="tm__line">
        <span class="tm__prompt">{user}@site ~ %</span> ls -la ./projets
      </p>
      <div class="tm__projects">
        {
          data.projects.map((p, i) => (
            <a class="tm__proj" href={p.url}>
              <span class="tm__proj-perm">drwxr-xr-x</span>
              <span class="tm__proj-name">{p.title}/</span>
              <span class="tm__proj-year">{p.year}</span>
              <span
                class="tm__proj-desc"
                data-i18n={`projects.${i}.description`}
              >
                {p.description}
              </span>
              <span class="tm__proj-tags"># {p.tags.join(" · ")}</span>
            </a>
          ))
        }
      </div>

      <p class="tm__line">
        <span class="tm__prompt">{user}@site ~ %</span> which -a $(skills)
      </p>
      <p class="tm__out tm__skills">
        {
          data.skills
            .map(
              (s) => `/usr/bin/${s.toLowerCase().replace(/[^a-z0-9]+/g, "")}`,
            )
            .join("\n")
        }
      </p>

      <p class="tm__line">
        <span class="tm__prompt">{user}@site ~ %</span> contact --now
      </p>
      <p class="tm__out">
        <a class="tm__mail" href={`mailto:${data.email}`}>&gt; {data.email}</a>
      </p>
      <p class="tm__out tm__links">
        {
          data.socials.map((s) => (
            <a href={s.url}>
              [{s.label}: {s.handle}]
            </a>
          ))
        }
      </p>

      <!-- REPL interactif (easter egg) -->
      <div class="tm__repl" data-repl>
        <div class="tm__repl-out" data-repl-out></div>
        <div class="tm__line tm__repl-line">
          <span class="tm__prompt">{user}@site ~ %</span><span
            class="tm__echo"
            data-repl-echo></span><span
            class="tm__cursor"
            data-repl-cursor
            aria-hidden="true"></span>
          <input
            class="tm__cmd"
            data-repl-input
            type="text"
            autocomplete="off"
            autocapitalize="off"
            spellcheck="false"
            aria-label="Terminal interactif — tapez une commande"
          />
        </div>
        <p class="tm__repl-hint">
          <span data-i18n="tm.hintpre">indice&nbsp;: commence à taper ou</span>{
            " "
          }
          <b>help</b>{" "}
          <span data-i18n="tm.hintpost">puis Entrée</span>
        </p>
      </div>
    </div>
  </div>

  <script
    is:inline
    define:vars={{
      user,
      content: { fr: replContent(data), en: replContent(portfolioEn) },
      STR: replText,
    }}
  >
    const root = document.querySelector("[data-repl]");
    if (root) {
      const input = root.querySelector("[data-repl-input]");
      const echoEl = root.querySelector("[data-repl-echo]");
      const out = root.querySelector("[data-repl-out]");
      const prompt = user + "@site ~ % ";
      const history = [];
      let hix = -1;

      // rendu d'une ligne de sortie : chaîne, ou objet { text, href } cliquable
      function lineNode(item) {
        const d = document.createElement("div");
        d.className = "tm__repl-l";
        if (item && typeof item === "object" && item.href) {
          const a = document.createElement("a");
          a.className = "tm__repl-link";
          a.href = item.href;
          a.textContent = item.text;
          if (/^https?:/.test(item.href)) {
            a.target = "_blank";
            a.rel = "noopener";
          }
          d.appendChild(a);
        } else {
          d.textContent = item == null ? "" : String(item);
        }
        return d;
      }
      const print = (item) => out.appendChild(lineNode(item));

      function echo(cmd) {
        const d = document.createElement("div");
        d.className = "tm__repl-l";
        const p = document.createElement("span");
        p.className = "tm__prompt";
        p.textContent = prompt;
        d.appendChild(p);
        d.appendChild(document.createTextNode(cmd));
        out.appendChild(d);
      }

      const lang = () => (document.documentElement.lang === "en" ? "en" : "fr");

      function run(raw) {
        const P = content[lang()];
        const t = STR[lang()];
        const cmd = raw.trim();
        const [name, ...args] = cmd.split(/\s+/);
        switch ((name || "").toLowerCase()) {
          case "":
            return [];
          case "help":
            return t.help;
          case "whoami":
            return [P.name + " — " + P.role, P.location];
          case "about":
          case "cat":
            return [P.about];
          case "ls":
          case "ll":
            return P.projects.map(
              (p) => p.title + "/  (" + p.year + ")  — " + p.description,
            );
          case "skills":
          case "stack":
            return [P.skills.join(" · ")];
          case "contact":
          case "mail":
            return [
              { text: P.email, href: "mailto:" + P.email },
              ...P.socials.map((s) => ({
                text: s.label + " : " + s.url,
                href: s.url,
              })),
            ];
          case "echo":
            return [args.join(" ")];
          case "date":
            return [new Date().toLocaleString(t.locale)];
          case "sudo":
            return [t.sudo];
          case "rm":
            return [t.rm];
          case "hello":
          case "salut":
            return [t.hello];
          case "clear":
            return "CLEAR";
          default:
            return [name + t.notfound];
        }
      }

      const setLine = (v) => {
        input.value = v;
        echoEl.textContent = v;
      };

      // miroir : le texte tapé s'affiche à côté du prompt, le curseur le suit
      input.addEventListener("input", () => {
        echoEl.textContent = input.value;
      });

      input.addEventListener("keydown", (e) => {
        if (e.key === "Enter") {
          const raw = input.value;
          echo(raw);
          if (raw.trim()) {
            history.push(raw);
            hix = history.length;
          }
          const res = run(raw);
          if (res === "CLEAR") out.replaceChildren();
          else res.forEach(print);
          setLine("");
          // défile jusqu'en bas pour garder la ligne de saisie visible
          // (la réserve de 104px sous l'univers la dégage de la barre d'action)
          requestAnimationFrame(() => {
            window.scrollTo({
              top: document.documentElement.scrollHeight,
              behavior: "smooth",
            });
          });
        } else if (e.key === "ArrowUp") {
          if (hix > 0) setLine(history[--hix]);
          e.preventDefault();
        } else if (e.key === "ArrowDown") {
          if (hix < history.length - 1) setLine(history[++hix]);
          else {
            hix = history.length;
            setLine("");
          }
          e.preventDefault();
        }
      });

      // clic dans le terminal → focus sans défiler (sauf sur un lien)
      root.addEventListener("click", (e) => {
        if (e.target.tagName !== "A") input.focus({ preventScroll: true });
      });

      // frappe directe : dès qu'on tape (terminal affiché), on capte la saisie
      // sans faire défiler la page ni déclencher le raccourci « r » du switcher
      document.addEventListener("keydown", (e) => {
        if (
          document.documentElement.getAttribute("data-universe") !== "terminal"
        )
          return;
        const ae = document.activeElement;
        if (ae === input) return;
        if (ae && (ae.tagName === "INPUT" || ae.tagName === "TEXTAREA")) return;
        if (e.metaKey || e.ctrlKey || e.altKey) return;
        if (e.key.length === 1 || e.key === "Backspace" || e.key === "Enter") {
          input.focus({ preventScroll: true });
          e.stopImmediatePropagation();
        }
      });
    }
  </script>
</section>

<style>
  .tm {
    --bg: #0a0f0a;
    --green: #33ff77;
    --dim: #1f8a49;
    --amber: #ffcf4d;
    background: radial-gradient(120% 120% at 50% 0%, #0d160d 0%, #060a06 70%);
    color: var(--green);
    font-family: "JetBrains Mono", ui-monospace, monospace;
    min-height: 100vh;
    padding: clamp(16px, 4vw, 48px) clamp(16px, 4vw, 48px) 104px;
    position: relative;
    overflow: hidden;
  }
  .tm__scanlines {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 3;
    background: repeating-linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0) 0px,
      rgba(0, 0, 0, 0) 2px,
      rgba(0, 0, 0, 0.25) 3px,
      rgba(0, 0, 0, 0.25) 3px
    );
    mix-blend-mode: multiply;
  }
  .tm__glow {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 2;
    background: radial-gradient(
      100% 80% at 50% 40%,
      rgba(51, 255, 119, 0.06),
      transparent 70%
    );
    animation: tm-flicker 4s infinite steps(60);
  }
  @keyframes tm-flicker {
    0%,
    97%,
    100% {
      opacity: 1;
    }
    98% {
      opacity: 0.82;
    }
    99% {
      opacity: 0.94;
    }
  }

  .tm__screen {
    position: relative;
    z-index: 1;
    max-width: 860px;
    margin: 0 auto;
    border: 1px solid rgba(51, 255, 119, 0.35);
    border-radius: 10px;
    box-shadow:
      0 0 0 1px rgba(51, 255, 119, 0.08),
      0 0 60px rgba(51, 255, 119, 0.08) inset;
    background: rgba(5, 12, 5, 0.6);
  }
  .tm__bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
    border-bottom: 1px solid rgba(51, 255, 119, 0.25);
  }
  .tm__dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }
  .tm__dot--r {
    background: #ff5f56;
  }
  .tm__dot--y {
    background: #ffbd2e;
  }
  .tm__dot--g {
    background: #27c93f;
  }
  .tm__bar-title {
    margin-left: 8px;
    font-size: 12px;
    opacity: 0.7;
    letter-spacing: 0.04em;
  }

  .tm__body {
    padding: clamp(18px, 4vw, 34px);
    font-size: clamp(13px, 1.6vw, 15px);
    line-height: 1.75;
  }
  .tm__body > * {
    animation: tm-reveal 0.01s linear both;
  }
  /* révélation en cascade : chaque bloc apparaît après le précédent */
  .tm__body > *:nth-child(1) {
    animation-delay: 0.05s;
  }
  .tm__body > *:nth-child(2) {
    animation-delay: 0.3s;
  }
  .tm__body > *:nth-child(3) {
    animation-delay: 0.5s;
  }
  .tm__body > *:nth-child(4) {
    animation-delay: 0.7s;
  }
  .tm__body > *:nth-child(5) {
    animation-delay: 0.95s;
  }
  .tm__body > *:nth-child(6) {
    animation-delay: 1.15s;
  }
  .tm__body > *:nth-child(7) {
    animation-delay: 1.4s;
  }
  .tm__body > *:nth-child(8) {
    animation-delay: 1.7s;
  }
  .tm__body > *:nth-child(9) {
    animation-delay: 1.95s;
  }
  .tm__body > *:nth-child(n + 10) {
    animation-delay: 2.2s;
  }
  @keyframes tm-reveal {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .tm__boot {
    color: var(--amber);
    opacity: 0.85;
    margin: 0 0 18px;
    font-size: 12px;
    letter-spacing: 0.02em;
  }
  .tm__line {
    margin: 18px 0 2px;
    color: #eafff0;
  }
  .tm__prompt {
    color: var(--dim);
    margin-right: 10px;
    user-select: none;
  }
  .tm__out {
    margin: 0;
    color: var(--green);
    text-shadow: 0 0 8px rgba(51, 255, 119, 0.35);
  }
  .tm__out--big {
    font-size: clamp(1.6rem, 6vw, 2.8rem);
    line-height: 1.1;
    font-weight: 700;
    margin: 4px 0;
    letter-spacing: 0.01em;
  }
  .tm__wrap {
    max-width: 66ch;
    color: #b7ffd0;
  }

  .tm__projects {
    display: grid;
    gap: 2px;
    margin: 6px 0;
  }
  .tm__proj {
    display: grid;
    grid-template-columns: auto 1fr auto;
    grid-template-areas:
      "perm name year"
      "desc desc desc"
      "tags tags tags";
    gap: 2px 16px;
    padding: 10px 12px;
    text-decoration: none;
    color: var(--green);
    border: 1px dashed transparent;
    transition:
      background 0.15s ease,
      border-color 0.15s ease;
  }
  .tm__proj:hover {
    background: rgba(51, 255, 119, 0.08);
    border-color: rgba(51, 255, 119, 0.4);
  }
  .tm__proj-perm {
    grid-area: perm;
    color: var(--dim);
  }
  .tm__proj-name {
    grid-area: name;
    color: #eafff0;
    font-weight: 700;
    text-shadow: 0 0 8px rgba(51, 255, 119, 0.4);
    text-decoration: underline;
    text-decoration-color: rgba(51, 255, 119, 0.5);
    text-underline-offset: 3px;
  }
  .tm__proj:hover .tm__proj-name {
    text-decoration-color: var(--green);
  }
  .tm__proj-year {
    grid-area: year;
    color: var(--amber);
  }
  .tm__proj-desc {
    grid-area: desc;
    color: #9fe6b8;
  }
  .tm__proj-tags {
    grid-area: tags;
    color: var(--dim);
    font-size: 0.85em;
  }

  .tm__skills {
    white-space: pre-wrap;
    color: #9fe6b8;
    line-height: 1.5;
  }
  .tm__mail {
    color: var(--amber);
    text-decoration: underline;
    text-decoration-color: rgba(255, 207, 77, 0.6);
    text-underline-offset: 2px;
    text-shadow: 0 0 8px rgba(255, 207, 77, 0.4);
  }
  .tm__mail:hover {
    text-decoration-color: var(--amber);
  }
  .tm__links {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 18px;
    margin-top: 4px;
  }
  .tm__links a {
    text-decoration: underline;
    text-decoration-color: rgba(51, 255, 119, 0.5);
    text-underline-offset: 2px;
  }
  .tm__links a:hover {
    color: #eafff0;
    text-decoration-color: var(--green);
  }

  .tm__cursor {
    display: inline-block;
    width: 9px;
    height: 1.05em;
    background: var(--green);
    vertical-align: text-bottom;
    box-shadow: 0 0 8px rgba(51, 255, 119, 0.6);
    animation: tm-blink 1.05s steps(2, start) infinite;
  }
  @keyframes tm-blink {
    50% {
      opacity: 0;
    }
  }

  /* ————— REPL interactif ————— */
  .tm__repl {
    cursor: text;
  }
  .tm__repl-out {
    display: grid;
    gap: 2px;
  }
  .tm__repl-l {
    color: #b7ffd0;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .tm__repl-line {
    position: relative;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    margin: 6px 0 0;
    cursor: text;
  }
  /* texte tapé, affiché juste après le prompt ; le curseur bloc le suit */
  .tm__echo {
    white-space: pre-wrap;
    word-break: break-word;
    color: #eafff0;
    text-shadow: 0 0 8px rgba(51, 255, 119, 0.35);
  }
  /* input réel : transparent, superposé à la ligne pour capter la frappe et
     les clics ; le curseur visible est le bloc .tm__cursor ci-dessus */
  .tm__cmd {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
    border: 0;
    outline: none;
    background: transparent;
    font: inherit;
    color: transparent;
    caret-color: transparent;
  }
  .tm__repl-hint {
    margin: 12px 0 0;
    font-size: 12px;
    color: var(--dim);
    opacity: 0.85;
  }
  .tm__repl-hint b {
    color: var(--amber);
    font-weight: 700;
  }
  /* liens dans la sortie interactive */
  .tm__repl-link {
    color: var(--amber);
    text-decoration: underline;
    text-decoration-color: rgba(255, 207, 77, 0.6);
    text-underline-offset: 2px;
  }
  .tm__repl-link:hover {
    text-decoration-color: var(--amber);
    text-shadow: 0 0 8px rgba(255, 207, 77, 0.4);
  }

  @media (prefers-reduced-motion: reduce) {
    .tm__body > *,
    .tm__glow {
      animation: none;
      opacity: 1;
    }
    .tm__cursor {
      animation: none;
    }
  }
</style>
